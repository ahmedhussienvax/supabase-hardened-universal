# ------------------------------------------------------------------------------
# SUPABASE HARDENED UNIVERSAL - ENVIRONMENT TEMPLATE
# ------------------------------------------------------------------------------

# 1. NETWORKING (Universal)
PROJECT_DOMAIN=localhost
SERVICE_URL_SUPABASEKONG=http://${PROJECT_DOMAIN}:8000

# 2. STUDIO CONFIG (Synthetic Platform)
STUDIO_DEFAULT_PROJECT="Development Project"
STUDIO_DEFAULT_ORGANIZATION="My Local Team"

# 3. SECRETS (Required)
SERVICE_PASSWORD_POSTGRES=postgres
SERVICE_PASSWORD_JWT=super-secret-jwt-key-change-me
SERVICE_PASSWORD_ADMIN=admin
SERVICE_USER_ADMIN=admin
SERVICE_PASSWORD_LOGFLARE=logflare-secret-token

# 4. SERVICE KEYS (Standard Supabase)
SERVICE_SUPABASEANON_KEY=your-anon-key
SERVICE_SUPABASESERVICE_KEY=your-service-role-key

# 5. HARDENING (Stability)
LOGFLARE_MEMORY_LIMIT=512M
KONG_PORT_MAPS=443:8000
